<Window x:Class="RegionToShare.ToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="96" Height="28"
        ResizeMode="NoResize">
  <Border Background="#333337" CornerRadius="4" Padding="4" Opacity="0.92">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="ResizeBtn" Width="28" Height="20" Margin="0,0,4,0" ToolTip="Toggle resize mode (Ctrl+R)">
        <TextBlock Text="⤢" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Button>
      <Button x:Name="StopBtn" Width="28" Height="20" ToolTip="Stop capture">
        <TextBlock Text="X" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Button>
    </StackPanel>
  </Border>
</Window>